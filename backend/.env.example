# Server Port
PORT=3000

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/maintainiq

# JWT authentication secret
JWT_SECRET=maintainiq-secret-key-12345!

# Google Gemini AI API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Cloudinary Integration (for media/evidence logs)
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_SECRET

# Application Base URL (Used for generating QR Codes and Public Asset Links)
# Locally this can be http://localhost:5173 or http://localhost:3000
# IN PRODUCTION ON VERCEL, set this to your FRONTEND URL!
APP_URL=http://localhost:3000
